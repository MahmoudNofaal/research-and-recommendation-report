@* Static sample comparison report used in the hero preview and sample modal. *@

<article class="overflow-hidden rounded-md border border-border-subtle bg-surface-card">
    <header class="flex flex-wrap items-start justify-between gap-4 border-b border-border-subtle bg-surface-hero px-4 py-4 sm:px-6">
        <div class="min-w-0 flex-1">
            <h3 class="text-body-md text-text-primary">SignalR vs gRPC vs WebSockets</h3>
            <div class="mt-2 flex flex-wrap gap-2">
                <span class="inline-flex items-center rounded-md bg-tag-sky/14 px-2 py-0.5 text-caption font-semibold text-tag-sky-text">Comparison</span>
                <span class="inline-flex items-center rounded-md bg-tag-violet/14 px-2 py-0.5 text-caption font-semibold text-tag-violet-text">Balanced</span>
                <span class="inline-flex items-center rounded-md bg-tag-neutral/14 px-2 py-0.5 text-caption font-semibold text-tag-neutral-text">Advanced</span>
            </div>
        </div>
        <div class="flex flex-col items-center gap-1" title="Quality score reflects structural completeness">
            <div class="relative flex h-14 w-14 items-center justify-center">
                <svg class="h-full w-full -rotate-90" viewBox="0 0 36 36" aria-hidden="true">
                    <circle cx="18" cy="18" r="15.5" fill="none" stroke="currentColor" class="text-border-subtle" stroke-width="3" />
                    <circle cx="18" cy="18" r="15.5" fill="none" stroke="currentColor" class="text-accent-success" stroke-width="3" stroke-dasharray="82 100" stroke-linecap="round" />
                </svg>
                <span class="absolute text-body-sm font-semibold text-accent-success">82</span>
            </div>
            <span class="text-caption text-text-tertiary">Quality</span>
        </div>
    </header>

    <div class="px-4 py-4 sm:px-6">
        <h4 class="text-caption font-semibold uppercase tracking-wide text-text-tertiary">Comparison Table</h4>
        <div class="mt-3 overflow-x-auto">
            <table class="w-full min-w-[320px] border-collapse text-body-sm">
                <thead>
                    <tr class="border-b border-border-subtle">
                        <th scope="col" class="px-3 py-2 text-left font-semibold text-text-secondary">Technology</th>
                        <th scope="col" class="px-3 py-2 text-left font-semibold text-text-secondary">Latency</th>
                        <th scope="col" class="px-3 py-2 text-left font-semibold text-text-secondary">Scalability</th>
                        <th scope="col" class="px-3 py-2 text-left font-semibold text-text-secondary">Ease of Use</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="border-b border-border-subtle">
                        <td class="px-3 py-2 text-text-primary">SignalR</td>
                        <td class="px-3 py-2 font-semibold text-accent-success">9/10</td>
                        <td class="px-3 py-2 font-semibold text-accent-success">8/10</td>
                        <td class="px-3 py-2 font-semibold text-accent-success">9/10</td>
                    </tr>
                    <tr class="border-b border-border-subtle">
                        <td class="px-3 py-2 text-text-primary">gRPC</td>
                        <td class="px-3 py-2 font-semibold text-accent-success">10/10</td>
                        <td class="px-3 py-2 font-semibold text-accent-success">9/10</td>
                        <td class="px-3 py-2 font-semibold text-tag-amber-text">6/10</td>
                    </tr>
                    <tr>
                        <td class="px-3 py-2 text-text-primary">WebSockets</td>
                        <td class="px-3 py-2 font-semibold text-accent-success">9/10</td>
                        <td class="px-3 py-2 font-semibold text-tag-amber-text">7/10</td>
                        <td class="px-3 py-2 font-semibold text-tag-amber-text">5/10</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="mt-4 flex items-start gap-3 rounded-md border border-border-subtle bg-tag-emerald/14 p-4">
            <svg class="mt-0.5 shrink-0 text-accent-success" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                <polyline points="22 4 12 14.01 9 11.01" />
            </svg>
            <p class="m-0 text-body-sm text-text-primary">
                <span class="font-semibold text-accent-success">Scenario recommendation:</span>
                For browser-first internal tools, SignalR offers the best balance of developer experience and real-time performance.
            </p>
        </div>
    </div>
</article>
