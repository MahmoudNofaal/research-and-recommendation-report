@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Understand it. Compare it. Decide with confidence.";
    ViewData["MetaDescription"] = "AI-generated research reports that explain unfamiliar topics clearly, compare your options side by side, and recommend a next step — structured for decisions, not chat.";
}

<div x-data="{ reportMode: 'research', sampleOpen: false }" @@keydown.escape.window="sampleOpen = false">

    @* ── 1. Hero + signature report-mode toggle ── *@
    <section class="px-4 pb-16 pt-12 sm:px-6 sm:pt-16 lg:pt-24" aria-labelledby="hero-heading">
        <div class="mx-auto max-w-6xl text-center">
            <h1 id="hero-heading" class="mx-auto max-w-3xl text-landing-display tracking-tight text-text-primary">
                Understand it. Compare it. Decide with confidence.
            </h1>
            <p class="mx-auto mt-6 max-w-2xl text-landing-lead text-text-secondary">
                AI-generated reports that explain unfamiliar topics clearly, or compare your options side by side,
                and recommend a next step — structured for decisions, not a wall of chat text.
            </p>
            <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
                <a class="btn-primary btn-lg" href="/Identity/Account/Register">Create your first report</a>
                <button type="button"
                        class="btn-secondary btn-lg"
                        x-on:click="sampleOpen = true"
                        aria-haspopup="dialog">
                    See a sample report
                </button>
            </div>
        </div>

        @* Signature element: mirrors the app's Report Mode choice *@
        <div class="mx-auto mt-12 max-w-4xl px-0 sm:mt-16">
            <p class="mb-4 text-center text-body-sm text-text-tertiary">Choose how you want to research — just like in the app</p>

            <div class="bg-surface-hero/80 rounded-xl border border-border-subtle p-4 shadow-panel sm:p-6"
                 role="region"
                 aria-label="Report mode preview">
                <div class="mx-auto flex max-w-lg rounded-full bg-surface-raised p-1" role="tablist" aria-label="Report mode">
                    <button type="button"
                            role="tab"
                            id="tab-research"
                            x-bind:aria-selected="reportMode === 'research'"
                            x-bind:tabindex="reportMode === 'research' ? 0 : -1"
                            aria-controls="panel-research"
                            x-on:click="reportMode = 'research'"
                            x-bind:class="reportMode === 'research'
                                ? 'bg-surface-active text-text-primary'
                                : 'text-text-secondary hover:text-text-primary'"
                            class="flex-1 rounded-full px-4 py-2.5 text-body-sm font-medium transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-accent-primary">
                        Learn one topic deeply
                    </button>
                    <button type="button"
                            role="tab"
                            id="tab-compare"
                            x-bind:aria-selected="reportMode === 'compare'"
                            x-bind:tabindex="reportMode === 'compare' ? 0 : -1"
                            aria-controls="panel-compare"
                            x-on:click="reportMode = 'compare'"
                            x-bind:class="reportMode === 'compare'
                                ? 'bg-surface-active text-text-primary'
                                : 'text-text-secondary hover:text-text-primary'"
                            class="flex-1 rounded-full px-4 py-2.5 text-body-sm font-medium transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-accent-primary">
                        Compare your options
                    </button>
                </div>

                <div class="mt-6">
                    <div id="panel-research"
                         role="tabpanel"
                         aria-labelledby="tab-research"
                         x-show="reportMode === 'research'"
                         x-cloak>
                        <partial name="Partials/_SingleTopicPreview" />
                    </div>
                    <div id="panel-compare"
                         role="tabpanel"
                         aria-labelledby="tab-compare"
                         x-show="reportMode === 'compare'"
                         x-cloak>
                        <partial name="Partials/_SampleComparisonReport" />
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ── 2. The fork: two ways to use it ── *@
    <section class="border-y border-border-subtle bg-surface-base/40 px-4 py-16 sm:px-6" aria-labelledby="fork-heading">
        <div class="mx-auto max-w-6xl">
            <header class="mx-auto max-w-2xl text-center">
                <h2 id="fork-heading" class="text-heading-md text-text-primary">Two ways to use it</h2>
                <p class="mt-3 text-body-sm text-text-secondary">
                    Every report starts with a mode choice — the same fork you saw above drives what gets generated.
                </p>
            </header>

            <div class="mt-12 grid gap-6 md:grid-cols-2">
                <article class="rounded-md border border-border-subtle bg-surface-card p-6 transition-colors duration-150 hover:border-border-default">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-tag-gold/14 text-tag-gold-text" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                    </div>
                    <h3 class="mt-4 text-heading-sm text-text-primary">Learn one topic deeply</h3>
                    <p class="mt-2 text-body-sm text-text-secondary">
                        Get a focused research report with explanation, key concepts, practical use cases, tradeoffs,
                        and a recommended approach — all in plain language matched to your audience and technical depth.
                    </p>
                    <ul class="mt-4 space-y-2 text-body-sm text-text-tertiary">
                        <li class="flex items-start gap-2"><span class="text-accent-primary" aria-hidden="true">→</span> Topic overview and why it matters</li>
                        <li class="flex items-start gap-2"><span class="text-accent-primary" aria-hidden="true">→</span> Visual explanation when helpful</li>
                        <li class="flex items-start gap-2"><span class="text-accent-primary" aria-hidden="true">→</span> Implementation notes or learning path</li>
                    </ul>
                </article>

                <article class="rounded-md border border-border-subtle bg-surface-card p-6 transition-colors duration-150 hover:border-border-default">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-tag-sky/14 text-tag-sky-text" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" />
                            <rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" />
                        </svg>
                    </div>
                    <h3 class="mt-4 text-heading-sm text-text-primary">Compare your options</h3>
                    <p class="mt-2 text-body-sm text-text-secondary">
                        Pit 2–8 options against weighted criteria. Get a side-by-side comparison table, a decision matrix,
                        and scenario-based recommendations for which option fits which situation.
                    </p>
                    <ul class="mt-4 space-y-2 text-body-sm text-text-tertiary">
                        <li class="flex items-start gap-2"><span class="text-accent-primary" aria-hidden="true">→</span> Explanation of each topic</li>
                        <li class="flex items-start gap-2"><span class="text-accent-primary" aria-hidden="true">→</span> Comparison table and decision matrix</li>
                        <li class="flex items-start gap-2"><span class="text-accent-primary" aria-hidden="true">→</span> Scenario-based recommendations</li>
                    </ul>
                </article>
            </div>
        </div>
    </section>

    @* ── 3. How it works ── *@
    <section class="px-4 py-16 sm:px-6" aria-labelledby="steps-heading">
        <div class="mx-auto max-w-6xl">
            <header class="mx-auto max-w-2xl text-center">
                <h2 id="steps-heading" class="text-heading-md text-text-primary">How it works</h2>
                <p class="mt-3 text-body-sm text-text-secondary">From topic to export in four steps.</p>
            </header>

            <ol class="landing-steps-connector mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
                <li class="relative">
                    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-accent-primary text-caption font-semibold text-white" aria-hidden="true">1</span>
                    <h3 class="mt-4 text-heading-sm text-text-primary">Tell it your topic</h3>
                    <p class="mt-2 text-body-sm text-text-secondary">Enter one topic to research, or list the options you want compared.</p>
                </li>
                <li class="relative">
                    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-accent-primary text-caption font-semibold text-white" aria-hidden="true">2</span>
                    <h3 class="mt-4 text-heading-sm text-text-primary">Set your preferences</h3>
                    <p class="mt-2 text-body-sm text-text-secondary">Choose audience, style, technical depth, and — for comparisons — your evaluation criteria.</p>
                </li>
                <li class="relative">
                    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-accent-primary text-caption font-semibold text-white" aria-hidden="true">3</span>
                    <h3 class="mt-4 text-heading-sm text-text-primary">AI generates structure</h3>
                    <p class="mt-2 text-body-sm text-text-secondary">Get a structured report with named sections — not a raw chat response.</p>
                </li>
                <li class="relative">
                    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-accent-primary text-caption font-semibold text-white" aria-hidden="true">4</span>
                    <h3 class="mt-4 text-heading-sm text-text-primary">Preview and export</h3>
                    <p class="mt-2 text-body-sm text-text-secondary">Review the report, then export as Markdown, PDF, Word, or HTML.</p>
                </li>
            </ol>
        </div>
    </section>

    @* ── 4. What's inside a report ── *@
    <section class="border-y border-border-subtle bg-surface-base/40 px-4 py-16 sm:px-6" aria-labelledby="contents-heading">
        <div class="mx-auto max-w-6xl">
            <header class="mx-auto max-w-2xl text-center">
                <h2 id="contents-heading" class="text-heading-md text-text-primary">What's inside a report</h2>
                <p class="mt-3 text-body-sm text-text-secondary">
                    Section names match the app's quality checks — so you know what a complete report includes.
                </p>
            </header>

            <div class="mt-12 grid gap-6 md:grid-cols-2">
                <div class="rounded-md border border-border-subtle bg-surface-card p-6">
                    <h3 class="text-heading-sm text-text-primary">Single-topic research</h3>
                    <nav class="mt-4" aria-label="Single-topic report sections">
                        <ol class="space-y-2 text-body-sm text-text-secondary">
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">01</span> Executive Summary</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">02</span> Topic Overview</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">03</span> Why the Topic Matters</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">04</span> Key Concepts and Terminology</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">05</span> Visual Explanation or Diagram</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">06</span> Practical Use Cases</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">07</span> Benefits, Risks, and Tradeoffs</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">08</span> Recommended Approach or Best Practices</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">09</span> Implementation Notes or Learning Path</li>
                        </ol>
                    </nav>
                </div>

                <div class="rounded-md border border-border-subtle bg-surface-card p-6">
                    <h3 class="text-heading-sm text-text-primary">Comparison report</h3>
                    <nav class="mt-4" aria-label="Comparison report sections">
                        <ol class="space-y-2 text-body-sm text-text-secondary">
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">01</span> Executive Summary</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">02</span> Introduction</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">03</span> Explanation of Each Topic</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">04</span> Relationships Between Topics</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">05</span> Comparison Table</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">06</span> Decision Matrix</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">07</span> Scenario-Based Recommendations</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">08</span> Risks and Tradeoffs</li>
                            <li class="landing-toc-item"><span class="text-caption text-text-tertiary">09</span> Implementation Notes</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </section>

    @* ── 5. Export formats ── *@
    <section class="px-4 py-16 sm:px-6" aria-labelledby="export-heading">
        <div class="mx-auto max-w-6xl text-center">
            <h2 id="export-heading" class="text-heading-md text-text-primary">Export in the format you need</h2>
            <p class="mt-3 text-body-sm text-text-secondary">Download the same report in any supported format.</p>

            <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
                <span class="inline-flex items-center gap-2 rounded-full border border-border-subtle bg-surface-card px-5 py-2.5 text-body-sm font-semibold text-text-primary transition-colors duration-150 hover:border-border-default">
                    @* Lucide: hash — represents Markdown's # heading syntax *@
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="9" x2="20" y2="9" /><line x1="4" y1="15" x2="20" y2="15" /><line x1="10" y1="3" x2="8" y2="21" /><line x1="16" y1="3" x2="14" y2="21" /></svg>
                    Markdown (.md)
                </span>
                <span class="inline-flex items-center gap-2 rounded-full border border-border-subtle bg-surface-card px-5 py-2.5 text-body-sm font-semibold text-text-primary transition-colors duration-150 hover:border-border-default">
                    @* Lucide: file-text — document with text lines *@
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><line x1="10" y1="9" x2="8" y2="9" /></svg>
                    PDF (.pdf)
                </span>
                <span class="inline-flex items-center gap-2 rounded-full border border-border-subtle bg-surface-card px-5 py-2.5 text-body-sm font-semibold text-text-primary transition-colors duration-150 hover:border-border-default">
                    @* Lucide: file-type — document with W *@
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><path d="M9 13v-1h6v1" /><path d="M11 18h2" /><path d="M12 12v6" /></svg>
                    Word (.docx)
                </span>
                <span class="inline-flex items-center gap-2 rounded-full border border-border-subtle bg-surface-card px-5 py-2.5 text-body-sm font-semibold text-text-primary transition-colors duration-150 hover:border-border-default">
                    @* Lucide: code — angle brackets for HTML *@
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" /></svg>
                    HTML (.html)
                </span>
            </div>
        </div>
    </section>

    @* ── 6. Engineering footnote ── *@
    <section class="px-4 pb-8 sm:px-6" aria-label="Technical details">
        <p class="mx-auto max-w-3xl text-center text-caption text-text-tertiary">
            Built on ASP.NET Core with Clean Architecture and a swappable AI-provider layer — currently Groq and Gemini.
        </p>
    </section>

    @* ── 7. Final CTA ── *@
    <section class="px-4 pb-16 sm:px-6" aria-labelledby="final-cta-heading">
        <div class="mx-auto max-w-3xl rounded-xl border border-border-subtle bg-surface-hero px-6 py-12 text-center landing-cta-glow sm:px-12">
            <h2 id="final-cta-heading" class="text-heading-md text-text-primary">Ready to generate your first report?</h2>
            <p class="mt-3 text-body-sm text-text-secondary">Sign up, pick a mode, and have a structured report in minutes.</p>
            <a class="btn-primary btn-lg mt-8" href="/Identity/Account/Register">Create your first report</a>
        </div>
    </section>

    @* Sample report modal *@
    <div x-show="sampleOpen"
         x-cloak
         class="fixed inset-0 z-[100] flex items-end justify-center p-4 sm:items-center"
         role="dialog"
         aria-modal="true"
         aria-labelledby="sample-dialog-title"
         x-trap.noscroll="sampleOpen">
        <div class="absolute inset-0 bg-bg-gradient-to/80 backdrop-blur-sm"
             x-on:click="sampleOpen = false"
             aria-hidden="true"></div>

        <div class="relative max-h-[90vh] w-full max-w-2xl overflow-y-auto rounded-xl border border-border-subtle bg-surface-base shadow-dropdown">
            <div class="sticky top-0 flex items-center justify-between border-b border-border-subtle bg-surface-base px-4 py-4 sm:px-6">
                <h2 id="sample-dialog-title" class="text-heading-sm text-text-primary">Sample comparison report</h2>
                <button type="button"
                        class="flex h-9 w-9 items-center justify-center rounded-full bg-surface-raised text-text-secondary transition-colors duration-150 hover:bg-surface-raised-hover hover:text-text-primary focus-visible:ring-2 focus-visible:ring-accent-primary"
                        x-on:click="sampleOpen = false"
                        aria-label="Close sample report">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
            </div>
            <div class="p-4 sm:p-6">
                <partial name="Partials/_SampleComparisonReport" />
            </div>
        </div>
    </div>
</div>
