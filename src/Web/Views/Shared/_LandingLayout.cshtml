<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ResearchReportGen</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="landing-page">
    <a class="skip-link" href="#main-content">Skip to main content</a>

    <header class="landing-header">
        <div class="landing-header__inner">
            <a class="landing-logo" asp-controller="Home" asp-action="Index">
                <span class="landing-logo__icon" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                        <line x1="16" y1="13" x2="8" y2="13" />
                        <line x1="16" y1="17" x2="8" y2="17" />
                        <polyline points="10 9 9 9 8 9" />
                    </svg>
                </span>
                <span class="landing-logo__text">ResearchReportGen</span>
            </a>
            <nav class="landing-nav" aria-label="Account">
                <a class="btn btn-secondary" href="/Identity/Account/Login">Log In</a>
                <a class="btn btn-primary" href="/Identity/Account/Register">Get Started Free</a>
            </nav>
        </div>
    </header>

    <main id="main-content" class="landing-main">
        @RenderBody()
    </main>

    <footer class="landing-footer">
        <div class="landing-footer__inner">
            <span>&copy; @DateTime.UtcNow.Year ResearchReportGen</span>
            <div class="landing-footer__links">
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
