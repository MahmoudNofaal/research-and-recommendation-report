{
    "ConnectionStrings": {
        "DefaultConnection": ""
    },
    "Authentication": {
        "Google": {
            "Enabled": false,
            "ClientId": "",
            "ClientSecret": "",
            "CallbackPath": "/signin-google"
        }
    },
    "Ai": {
        "DefaultProvider": "Fake",
        "MaxRetries": 2,
        "TimeoutSeconds": 60,
