{
    "ConnectionStrings": {
        "DefaultConnection": "Server = .; Database = ResearchReportGenerator; Integrated Security = SSPI; TrustServerCertificate = True;"
    },
    "Authentication": {
        "Google": {
            "Enabled": false,
            "ClientId": "",
            "ClientSecret": "",
            "CallbackPath": "/signin-google"
        }
    },
    "Ai": {
        "DefaultProvider": "Fake",
        "MaxRetries": 1,
        "TimeoutSeconds": 30,
        "Groq": {
            "Enabled": false,
            "ModelName": "llama-3.1-8b-instant",
            "ApiKey": ""
        },
        "Gemini": {
            "Enabled": false,
            "ModelName": "gemini-1.5-flash",
            "ApiKey": ""
        }
    },
    "ReportGeneration": {
        "MaximumTopics": 8,
        "MaximumCriteria": 12,
        "MaximumMarkdownCharacters": 20000,
        "EnableLiveResearch": false,
        "EnableVisualExplanations": true
    },
    "Exports": {
        "DefaultFormat": "Markdown",
        "RetainExportRecordsDays": 7,
        "EnableMarkdown": true,
        "EnableHtml": true,
        "EnablePdf": true,
        "EnableDocx": true
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    }
}
