@* Views/Shared/Partials/_SegmentedControl.cshtml
   Usage: <partial name="Partials/_SegmentedControl" model='new[] {
              ("kanban", "Kanban"), ("table", "Table View"), ("timeline", "Timeline View") }' />
   Alpine.js handles the active pill highlight; htmx swaps the actual content below.
*@
@model (string Value, string Label)[]

<div class="bg-surface-raised rounded-full p-1 flex" x-data="{ active: '@Model.First().Value' }">
    @foreach (var (value, label) in Model)
    {
        <button type="button"
                x-on:click="active = '@value'"
                x-bind:class="active === '@value'
                    ? 'bg-surface-active text-text-primary'
                    : 'text-text-secondary hover:text-text-primary'"
                class="px-4 py-2 rounded-full text-body-sm font-medium transition-colors duration-150"
                hx-get="/Reports/View/@value"
                hx-target="#report-board"
                hx-swap="innerHTML">
            @label
        </button>
    }
</div>

@* The target container in the parent view:
   <div id="report-board">
       <partial name="_KanbanView" model="Model.KanbanData" />
   </div>
*@
