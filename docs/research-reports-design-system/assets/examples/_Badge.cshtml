@* Views/Shared/Partials/_Badge.cshtml
   Usage: <partial name="Partials/_Badge" model='new BadgeViewModel { Label = "High", Tag = "rose" }' />
   Tag must be one of: rose, amber, sky, violet, gold, emerald, neutral (see design-tokens.md)
*@
@model ResearchReports.Web.ViewModels.BadgeViewModel

@{
    var bgClass = $"bg-tag-{Model.Tag}/14";
    var textClass = $"text-tag-{Model.Tag}-text";
}

<span class="inline-flex items-center rounded-md px-2 py-0.5 text-caption @bgClass @textClass">
    @Model.Label
</span>

@* Corresponding C# view model (put in ViewModels/BadgeViewModel.cs):

    public class BadgeViewModel
    {
        public string Label { get; set; } = string.Empty;
        public string Tag { get; set; } = "neutral"; // rose | amber | sky | violet | gold | emerald | neutral
    }
*@
